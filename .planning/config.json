{
  "model_profile": "adaptive",
  "workflow": {
    "research": true,
    "plan_check": true,
    "verifier": true,
    "tdd_mode": true,
    "code_review": true,
    "code_review_depth": "standard",
    "ui_phase": true,
    "ui_review": true,
    "ui_safety_gate": true,
    "ai_integration_phase": true,
    "pattern_mapper": true,
    "nyquist_validation": true,
    "skip_discuss": false,
    "auto_advance": true,
    "use_worktrees": true
  },
  "git": {
    "branching_strategy": "none",
    "create_tag": true
  },
  "commit_docs": true,
  "plan_review": {
    "source_grounding": true
  },
  "intel": {
    "enabled": true
  },
  "graphify": {
    "enabled": true,
    "auto_update": false
  },
  "hooks": {
    "context_warnings": true
  },
  "phase_id_convention": "v{major}.{minor}"
}
